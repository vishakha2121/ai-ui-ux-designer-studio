*.iml
*.iws
*.ipr
.idea_modules/
.idea/
*.swp
*.swo
*~

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
.*.swp

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock

