logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =====================
# Temporary Files
# =====================

tmp/
temp/
*.tmp
*.temp
*.cache
*.swp
*.swo

# =====================
# Testing
# =====================

coverage/
.nyc_output/
test-results/
jest-results.json
jest-coverage/

# =====================
# Build Outputs
# =====================

build/
dist/
out/
*.min.js
*.min.css

# =====================
# Misc
# =====================

*.zip
*.tar.gz
*.rar
*.7z
*.bak
*.old
*.orig
*.rej
*.patch
*.diff

# =====================
# Project Specific
# =====================

# Backend specific
backend/.env
backend/venv/
backend/__pycache__/
backend/*.pyc
backend/alembic/versions/*.pyc
backend/instance/

# Frontend specific
frontend/.env
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
frontend/.cache/

# Database specific
database/backup/
database/*.dump
database/*.backup
database/pgdata/

# SSL Certificates
*.pem
*.key
*.crt
*.csr

# JWT keys
jwtRS256.key
jwtRS256.key.pub

# Redis dumps
dump.rdb

# Production config files
config.production.json
config.staging.json

